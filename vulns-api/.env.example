# MongoDB
MONGODB_URI=mongodb://localhost:27017/vulnsdb

# Server
PORT=3000

# API Key para operaciones de escritura (POST, PUT, DELETE)
# Genera una con: node -e "const {v4}=require('uuid'); console.log(v4())"
API_KEY=tu-api-key-secreta-aqui

# NVD API Key (opcional, aumenta el rate limit)
# Regístrate en https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Intervalo de sincronización con APIs externas (en ms). Default: 1 hora
SYNC_INTERVAL=3600000
